# ============================================================
# PhantomBot Environment Variables
# ============================================================
# SECURITY WARNING: Never commit the real .env file to git.
# Copy this template and fill in your actual values:
#   cp .env.example .env
#   chmod 600 .env
# ============================================================

# OpenRouter API key for LLM supervisor (free models)
OPENROUTER_KEY=sk-or-v1-your-key-here

# Freqtrade API server credentials (used by dashboard)
FT_API_USERNAME=freqtrade
FT_API_PASSWORD=change_me_strong_password
FT_JWT_SECRET=change_me_random_32_char_secret
FT_WS_TOKEN=change_me_random_token

# Exchange API keys (leave empty for paper trading)
EXCHANGE_KEY=
EXCHANGE_SECRET=
