{
  "max_open_trades": 10,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.85,
  "fiat_display_currency": "USD",
  "timeframe": "1m",
  "dry_run": true,
  "dry_run_wallet": 100.0,
  "cancel_open_orders_on_exit": true,
  "trading_mode": "spot",
  "margin_mode": "",
  "unfilledtimeout": {
    "entry": 5,
    "exit": 5,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "ccxt_config": {
      "defaultType": "spot",
      "enableRateLimit": true
    },
    "ccxt_async_config": {},
    "pair_whitelist": [],
    "pair_blacklist": [
      "BNB/.*",
      ".*UP/USDT",
      ".*DOWN/USDT",
      ".*BULL/USDT",
      ".*BEAR/USDT",
      "SHIB/USDT",
      "DOGE/USDT",
      "PEPE/USDT",
      "FLOKI/USDT",
      "LUNC/USDT",
      "LUNA/USDT"
    ]
  },
  "pairlists": [
    {
      "method": "VolumePairList",
      "number_assets": 30,
      "sort_key": "quoteVolume",
      "min_value": 10000000,
      "refresh_period": 1800
    },
    {
      "method": "AgeFilter",
      "min_days_listed": 30
    },
    {
      "method": "VolatilityFilter",
      "lookback_days": 3,
      "min_volatility": 0.02,
      "max_volatility": 0.7
    },
    {
      "method": "RangeStabilityFilter",
      "lookback_days": 3,
      "min_rate_of_change": 0.015,
      "refresh_period": 1440
    },
    {
      "method": "SpreadFilter",
      "max_spread_ratio": 0.005
    },
    {
      "method": "PriceFilter",
      "min_price": 1e-07,
      "max_price": 100000
    },
    {
      "method": "ShuffleFilter"
    }
  ],
  "api_server": {
    "enabled": true,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "CHANGE_ME_GENERATE_A_RANDOM_SECRET",
    "ws_token": "CHANGE_ME_GENERATE_A_RANDOM_TOKEN",
    "CORS_origins": [],
    "username": "CHANGE_ME",
    "password": "CHANGE_ME"
  },
  "bot_name": "PhantomBot",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  },
  "strategy": "PhantomStrategy",
  "strategy-path": "/path/to/strategies",
  "db_url": "sqlite:///user_data/tradesv3.sqlite",
  "logfile": "user_data/logs/freqtrade.log",
  "dataformat_ohlcv": "json",
  "dataformat_trades": "jsongz",
  "order_types": {
    "entry": "limit",
    "exit": "market",
    "emergency_exit": "market",
    "force_exit": "market",
    "stoploss": "market",
    "stoploss_on_exchange": false,
    "stoploss_on_exchange_interval": 60
  },
  "order_time_in_force": {
    "entry": "gtc",
    "exit": "gtc"
  },
  "min_stake_amount": 10.0
}
